#!/bin/bash
# ark-usage — 一键查询火山方舟 Coding Plan / AgentPlan 用量
# 依赖: arkcli, jq, bc
# 项目: https://github.com/midasism/ark-usage
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'
DIM='\033[2m'

usage() {
    cat <<'EOF'
ark-usage — 火山方舟套餐用量一键查询

用法:
  ark-usage             套餐额度快照（含重置倒计时）
  ark-usage -w          持续刷新 (每 30s)
  ark-usage -h          帮助

首次使用会自动检测 arkcli 安装和登录状态。
EOF
    exit 0
}

WATCH=false

while getopts "wh" opt; do
    case $opt in
        w) WATCH=true ;;
        h) usage ;;
        *) usage ;;
    esac
done

# ═══════════════════════════════════════════════
# Step 0: 环境检测
# ═══════════════════════════════════════════════

# 0.1 检测 arkcli 是否安装
if ! command -v arkcli &>/dev/null; then
    echo ""
    echo -e "  ${YELLOW}⚠ 未检测到 arkcli，正在自动安装…${NC}"
    echo ""
    if command -v npm &>/dev/null; then
        npm install -g @volcengine/ark-cli 2>&1 || {
            echo ""
            echo -e "  ${RED}✗ 安装失败，请手动运行:${NC}"
            echo -e "    ${BOLD}npm install -g @volcengine/ark-cli${NC}"
            exit 1
        }
        echo ""
        echo -e "  ${GREEN}✓ arkcli 安装完成${NC}"
    else
        echo -e "  ${RED}✗ 未检测到 Node.js，请先安装:${NC}"
        echo -e "    ${BOLD}https://nodejs.org${NC} （下载 LTS 版本）"
        echo -e "  ${DIM}安装后重新打开终端，再运行 ark-usage${NC}"
        exit 1
    fi
fi

# 0.2 检测登录状态，未登录则自动拉起登录窗口
check_login() {
    local status
    status=$(arkcli auth status 2>/dev/null) || true
    if echo "$status" | jq -e '.logged_in == true' &>/dev/null; then
        return 0
    fi

    echo ""
    echo -e "  ${YELLOW}🔐 未登录火山方舟，正在打开登录页面…${NC}"
    echo -e "  ${DIM}请在浏览器中扫码或输入手机号登录${NC}"
    echo ""

    arkcli auth login 2>&1 || {
        echo ""
        echo -e "  ${RED}✗ 登录失败，请手动运行: arkcli auth login${NC}"
        exit 1
    }

    # 二次确认
    status=$(arkcli auth status 2>/dev/null) || true
    if ! echo "$status" | jq -e '.logged_in == true' &>/dev/null; then
        echo -e "  ${RED}✗ 登录未成功，请手动运行: arkcli auth login${NC}"
        exit 1
    fi

    echo ""
    echo -e "  ${GREEN}✓ 登录成功${NC}"
}

check_login

# ═══════════════════════════════════════════════
# 工具函数
# ═══════════════════════════════════════════════

bar() {
    local pct=$1 width=20
    local filled=$(echo "$pct * $width / 100" | bc -l | cut -d. -f1)
    local empty=$((width - filled))
    local color="$GREEN"
    if (( $(echo "$pct > 80" | bc -l) )); then color="$RED"
    elif (( $(echo "$pct > 50" | bc -l) )); then color="$YELLOW"
    fi
    printf "${color}"
    for ((i=0; i<filled; i++)); do printf "█"; done
    for ((i=0; i<empty; i++)); do printf "░"; done
    printf "${NC}"
}

label_cn() {
    case $1 in
        "5h")      echo " 5h     " ;;
        "session") echo " 会话    " ;;
        "daily")   echo " 日     " ;;
        "weekly")  echo " 周     " ;;
        "monthly") echo " 月     " ;;
        *)         printf "%-8s" "$1" ;;
    esac
}

countdown() {
    local reset_at=$1 ts reset_ts diff
    [ -z "$reset_at" ] || [ "$reset_at" = "null" ] && return
    reset_ts=$(date -jf "%Y-%m-%dT%H:%M:%S%z" \
        "$(echo "$reset_at" | sed 's/\([+-][0-9]\{2\}\):\([0-9]\{2\}\)/\1\2/')" "+%s" 2>/dev/null) || return
    ts=$(date +%s); diff=$((reset_ts - ts))
    [ $diff -lt 0 ] && { echo "已重置"; return; }
    [ $diff -lt 3600 ] && { echo "$((diff/60))分钟后重置"; return; }
    [ $diff -lt 86400 ] && { echo "$((diff/3600))小时$(((diff%3600)/60))分钟后重置"; return; }
    echo "$((diff/86400))天后重置"
}

fmt_reset() {
    local t=$1
    [ -z "$t" ] || [ "$t" = "null" ] && return
    if [[ "$OSTYPE" == "darwin"* ]]; then
        date -jf "%Y-%m-%dT%H:%M:%S%z" \
            "$(echo "$t" | sed 's/\([+-][0-9]\{2\}\):\([0-9]\{2\}\)/\1\2/')" "+%m/%d %H:%M" 2>/dev/null || echo "$t"
    else
        date -d "$t" "+%m/%d %H:%M" 2>/dev/null || echo "$t"
    fi
}

product_label() {
    case "$1" in
        "agent-plan")      echo "🤖 Agent Plan 个人版" ;;
        "agent-plan-team") echo "🤖 Agent Plan 团队版" ;;
        "coding-plan")     echo "💻 Coding Plan" ;;
        "coding-plan-team") echo "💻 Coding Plan 团队版" ;;
        *)                 echo "📦 $1" ;;
    esac
}

# ═══════════════════════════════════════════════
# 套餐额度
# ═══════════════════════════════════════════════

show_plan() {
    local data
    data=$(arkcli usage plan 2>&1) || {
        echo ""
        echo -e "  ${RED}✗ 查询失败${NC}"
        echo -e "  ${DIM}可能是登录过期，试试: arkcli auth login${NC}"
        return 1
    }

    local account
    account=$(echo "$data" | jq -r '.viewer.user_name // .viewer.account_id // "unknown"')

    echo ""
    echo -e "${BOLD}${CYAN}╭──────────────────────────────────────────────╮${NC}"
    echo -e "${BOLD}${CYAN}│${NC}  🔥 火山方舟 · 套餐用量                        ${BOLD}${CYAN}│${NC}"
    echo -e "${BOLD}${CYAN}│${NC}  ${DIM}${account}${NC}                              ${BOLD}${CYAN}│${NC}"
    echo -e "${BOLD}${CYAN}╰──────────────────────────────────────────────╯${NC}"
    echo ""

    local count
    count=$(echo "$data" | jq '.items | length')

    if [ "$count" -eq 0 ]; then
        echo -e "  ${YELLOW}⚠ 未找到有效订阅套餐${NC}"
        echo -e "  ${DIM}订阅地址: https://console.volcengine.com/ark/region:cn-beijing/plans${NC}"
        echo ""
        return
    fi

    for i in $(seq 0 $((count - 1))); do
        local product subscribed tier
        product=$(echo "$data" | jq -r ".items[$i].product")
        subscribed=$(echo "$data" | jq -r ".items[$i].subscribed")
        tier=$(echo "$data" | jq -r ".items[$i].tier // empty")

        [ "$subscribed" != "true" ] && continue

        local plabel
        plabel=$(product_label "$product")
        [ -n "$tier" ] && plabel="$plabel ($tier)"

        echo -e "  ${BOLD}$plabel${NC}"
        echo -e "  ${DIM}────────────────────────────────────────────${NC}"

        local periods pcount
        periods=$(echo "$data" | jq -r ".items[$i].periods")
        pcount=$(echo "$periods" | jq 'length')

        for j in $(seq 0 $((pcount - 1))); do
            local label_text pct used total reset_str
            label_text=$(echo "$periods" | jq -r ".[$j].label")
            pct=$(echo "$periods" | jq -r ".[$j].percent // 0")
            used=$(echo "$periods" | jq -r ".[$j].used // empty")
            total=$(echo "$periods" | jq -r ".[$j].total // empty")
            reset_str=$(fmt_reset "$(echo "$periods" | jq -r ".[$j].reset_at // empty")")

            printf "  %s  %s  ${BOLD}%5.1f%%${NC}" "$(label_cn "$label_text")" "$(bar "$pct")" "$pct"

            if [ -n "$used" ] && [ -n "$total" ]; then
                printf "  ${DIM}(%s/%s)${NC}" "$used" "$total"
            fi
            printf "  ${DIM}↻ %s${NC}" "$reset_str"

            local cd
            cd=$(countdown "$(echo "$periods" | jq -r ".[$j].reset_at // empty")")
            [ -n "$cd" ] && printf " ${DIM}[%s]${NC}" "$cd"
            echo ""
        done
        echo ""
    done
}

# ═══════════════════════════════════════════════
# 主流程
# ═══════════════════════════════════════════════

run_once() {
    show_plan
    echo -e "  ${DIM}$(date '+%H:%M:%S')${NC}"
    echo ""
}

if [ "$WATCH" = true ]; then
    echo -e "${DIM}每 30s 刷新，Ctrl+C 退出${NC}"
    sleep 1
    while true; do
        clear
        run_once
        sleep 30
    done
else
    run_once
fi
